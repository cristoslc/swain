<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}{% if title != site.title %} | {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="alternate" type="application/feed+xml" title="{{ site.title }}" href="{{ '/feed.xml' | url }}">
</head>
<body>
  <header class="site-header">
    <div class="wrapper">
      <a href="{{ '/' | url }}" class="site-title">{{ site.title }}</a>
      <nav class="site-nav">
        <a href="{{ '/about/' | url }}">About</a>
      </nav>
    </div>
  </header>

  <main class="page-content" aria-label="Content">
    <div class="wrapper">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="wrapper">
      <p>&copy; {{ site.author }} {{ site.title }} | <a href="https://github.com/cristoslc/swain">GitHub</a></p>
    </div>
  </footer>
</body>
</html>
