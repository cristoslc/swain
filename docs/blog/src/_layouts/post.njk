---
layout: base.njk
---

<article class="post">
  <header class="post-header">
    <h1 class="post-title">{{ title }}</h1>
    <time class="post-date" datetime="{{ published or date }}">{{ (published or date) | dateFormat }}</time>
  </header>
  
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
