# Secrets and local config
.env
.env.local
.env.*.local

# Git worktrees (ADR-034)
.worktrees/

# Python
__pycache__/
*.pyc
*.pyo

# Runtime artifacts
*.log
SESSION-ROADMAP.md

# .agents runtime artifacts (track code, ignore state)
.agents/*.log
.agents/*.json
.agents/.env
.agents/cache/
.agents/hook-state/
.agents/search-snapshots/
.agents/session.json
.agents/specwatch-ignore
.agents/worktrees/
.agents/.agents

# .claude runtime state (track skills symlink and settings, ignore local overrides and worktrees)
.claude/settings.local.json
.claude/worktrees/

# Skill eval workspaces
*-workspace/

# OS files
.DS_Store
Thumbs.db

# Node
node_modules/

# Skill installation artifacts (consumer-side)
skills-lock.json

# Dolt database files (added by bd init)
.dolt/
*.db

# Installed skills (consumer-side)
# Ignored here because they are usually mirrored in skills/ for publishing

# Ignore all skills, then un-ignore swain's own skills
skills/*
!skills/swain/
!skills/swain-*/

