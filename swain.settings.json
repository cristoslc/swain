{
  "editor": "auto",
  "fileBrowser": "auto",
  "terminal": {
    "tabNameFormat": "{project} @ {branch}"
  },
  "sync": {
    "scanners": {
      "gitleaks": { "enabled": true },
      "trufflehog": { "enabled": false },
      "trivy": { "enabled": false, "scanners": ["vuln", "license"], "severity": "HIGH,CRITICAL" },
      "osv-scanner": { "enabled": false }
    }
  },
  "dispatch": {
    "model": "claude-sonnet-4-6",
    "maxTurns": 15,
    "labels": ["agent-dispatch", "swain"],
    "autoTrigger": true
  },
  "stage": {
    "motd": {
      "refreshInterval": 5,
      "spinnerStyle": "braille"
    },
    "defaultLayout": "focus"
  }
}
