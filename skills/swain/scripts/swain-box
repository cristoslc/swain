#!/bin/sh
# swain-box — Run Claude Code in a Docker Desktop sandbox (SPEC-067)
# Usage: ./swain-box [path]
#
# With no argument, uses $PWD as the project root.
# With a path argument, uses that directory as the project root.
#
# Sandbox scoping: One sandbox per project directory (named claude-<dirname>).
# Git worktrees do NOT get separate sandboxes — they share the project's
# sandbox. If you need per-worktree isolation, run swain-box from the
# worktree's directory to create a distinct sandbox for it.
#
# Authentication:
#   Docker Sandboxes' MITM proxy does NOT support Claude Max/Pro OAuth
#   (docker/desktop-feedback#198). The proxy cannot tunnel traffic to
#   api.claude.ai — it MITMs the TLS connection, which the upstream
#   server rejects. This means ANTHROPIC_API_KEY (API billing) is the
#   only working auth path in Docker Sandboxes.
#
#   Set ANTHROPIC_API_KEY in ~/.zshrc BEFORE starting Docker Desktop.
#   The sandbox daemon reads env vars from the shell profile at startup,
#   not from the current shell session.
#
#   For Max/Pro subscription usage without API billing, use the Tier 1
#   native launcher instead: scripts/claude-sandbox
#
# Requires Docker Desktop 4.58+ (for the 'docker sandbox' subcommand).

set -eu

# --- Argument parsing ---
TARGET_PATH=""
for arg in "$@"; do
    case "$arg" in
        *) TARGET_PATH="$arg" ;;
    esac
done

# --- Docker availability check ---
if ! command -v docker >/dev/null 2>&1; then
    echo "swain-box: 'docker' not found on PATH." >&2
    echo "Install Docker Desktop: https://www.docker.com/products/docker-desktop/" >&2
    exit 1
fi

# --- docker sandbox subcommand check (Docker Desktop 4.58+) ---
if ! docker sandbox --help >/dev/null 2>&1; then
    echo "swain-box: 'docker sandbox' subcommand is not available." >&2
    echo "Requires Docker Desktop 4.58 or later." >&2
    echo "Download: https://www.docker.com/products/docker-desktop/" >&2
    exit 1
fi

# --- Resolve target path ---
TARGET_PATH="${TARGET_PATH:-$PWD}"

# Resolve to absolute path without using realpath (not portable)
ABSOLUTE_PATH="$(cd "$TARGET_PATH" && pwd)" || {
    echo "swain-box: path does not exist or is not accessible: $TARGET_PATH" >&2
    exit 1
}

# --- Derive sandbox name (matches docker sandbox's default: agent-workdir) ---
WORKDIR_NAME="$(basename "$ABSOLUTE_PATH")"
SANDBOX_NAME="claude-${WORKDIR_NAME}"

# --- Max/OAuth warning (docker/desktop-feedback#198) ---
# Docker Sandboxes' MITM proxy cannot tunnel to api.claude.ai, so OAuth
# (Max/Pro subscription) does not work. Only ANTHROPIC_API_KEY works.
# Detect when no API key is available and warn before launch.
_has_api_key=0
# Check current shell (won't be forwarded, but indicates user intent)
[ -n "${ANTHROPIC_API_KEY:-}" ] && _has_api_key=1
# Check shell profile (what Docker Desktop actually reads)
if [ "$_has_api_key" = "0" ]; then
    for _profile in "$HOME/.zshrc" "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
        if [ -f "$_profile" ] && grep -q 'ANTHROPIC_API_KEY' "$_profile" 2>/dev/null; then
            _has_api_key=1
            break
        fi
    done
fi
if [ "$_has_api_key" = "0" ]; then
    echo "" >&2
    echo "swain-box: WARNING — No ANTHROPIC_API_KEY detected." >&2
    echo "" >&2
    echo "  Docker Sandboxes cannot use Claude Max/Pro subscriptions (OAuth)." >&2
    echo "  The MITM proxy breaks api.claude.ai traffic (docker/desktop-feedback#198)." >&2
    echo "  You will see 'Credit balance too low' errors without an API key." >&2
    echo "" >&2
    echo "  To fix: export ANTHROPIC_API_KEY in ~/.zshrc, then restart Docker Desktop." >&2
    echo "  For Max/Pro without API billing, use the Tier 1 native launcher instead:" >&2
    echo "    scripts/claude-sandbox" >&2
    echo "" >&2
fi

# --- Fix apiKeyHelper injection (docker/for-mac#7842) ---
# Docker Desktop < 4.60.1 injected 'apiKeyHelper: "echo proxy-managed"' into
# sandbox settings, which overrides OAuth and forces API key mode.
# Clean it up if the sandbox already exists.
# NOTE: Use sh -c with $HOME — tilde (~) expands on the HOST, not inside the
# sandbox, so ~/.claude/ resolves to /Users/<host-user>/.claude/ which doesn't
# exist at /home/agent/.claude/ inside the VM.
if docker sandbox ls --format '{{.Sandbox}}' 2>/dev/null | grep -qx "$SANDBOX_NAME"; then
    _has_helper=$(docker sandbox exec "$SANDBOX_NAME" \
        sh -c 'grep -c "\"apiKeyHelper\"" "$HOME/.claude/settings.json"' 2>/dev/null || echo "0")
    if [ "$_has_helper" != "0" ]; then
        echo "swain-box: removing stale apiKeyHelper injection (docker/for-mac#7842)..." >&2
        docker sandbox exec "$SANDBOX_NAME" \
            sh -c 'sed -i "/\"apiKeyHelper\"/d" "$HOME/.claude/settings.json"' 2>/dev/null || true
    fi
fi

# --- Launch ---
exec docker sandbox run claude "$ABSOLUTE_PATH" -- --dangerously-skip-permissions
