#!/bin/sh
# swain-box — Run Claude Code in a Docker Desktop sandbox (SPEC-067)
# Usage: ./swain-box [--api-key] [path]
#
# With no argument, uses $PWD as the project root.
# With a path argument, uses that directory as the project root.
#
# Credentials (default): uses CLAUDE_CODE_OAUTH_TOKEN (Claude Max subscription).
#   ANTHROPIC_API_KEY is unset before launch to prevent it from overriding OAuth.
#   If CLAUDE_CODE_OAUTH_TOKEN is not set, attempts to fetch it from macOS Keychain.
#
# --api-key: opt into API key mode — keeps ANTHROPIC_API_KEY, skips OAuth handling.
#
# Requires Docker Desktop 4.58+ (for the 'docker sandbox' subcommand).

set -eu

# --- Argument parsing ---
USE_API_KEY=0
TARGET_PATH=""
for arg in "$@"; do
    case "$arg" in
        --api-key) USE_API_KEY=1 ;;
        *) TARGET_PATH="$arg" ;;
    esac
done

# --- Docker availability check ---
if ! command -v docker >/dev/null 2>&1; then
    echo "swain-box: 'docker' not found on PATH." >&2
    echo "Install Docker Desktop: https://www.docker.com/products/docker-desktop/" >&2
    exit 1
fi

# --- docker sandbox subcommand check (Docker Desktop 4.58+) ---
if ! docker sandbox --help >/dev/null 2>&1; then
    echo "swain-box: 'docker sandbox' subcommand is not available." >&2
    echo "Requires Docker Desktop 4.58 or later." >&2
    echo "Download: https://www.docker.com/products/docker-desktop/" >&2
    exit 1
fi

# --- Credential handling ---
if [ "$USE_API_KEY" = "1" ]; then
    # API key mode: use ANTHROPIC_API_KEY as-is
    if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
        echo "swain-box: ERROR: --api-key specified but ANTHROPIC_API_KEY is not set." >&2
        exit 1
    fi
    echo "swain-box: using API key mode (--api-key)." >&2
else
    # OAuth mode (default): unset API key to prevent fallback
    # Claude Code will use its own stored credentials from the mounted config
    unset ANTHROPIC_API_KEY 2>/dev/null || true
    echo "swain-box: using OAuth mode (config mounted from host)." >&2
fi

# --- Resolve target path ---
TARGET_PATH="${TARGET_PATH:-$PWD}"

# Resolve to absolute path without using realpath (not portable)
ABSOLUTE_PATH="$(cd "$TARGET_PATH" && pwd)" || {
    echo "swain-box: path does not exist or is not accessible: $TARGET_PATH" >&2
    exit 1
}

# --- Launch ---
# Mount Claude Code config so the sandbox uses the authenticated session
# This avoids credential passing and lets Claude Code use its stored OAuth credentials
CLAUDE_CONFIG_HOME="${CLAUDE_CONFIG_HOME:-$HOME/.claude}"
exec docker sandbox run \
    -v "$CLAUDE_CONFIG_HOME:/root/.claude:ro" \
    claude "$ABSOLUTE_PATH" --dangerously-skip-permissions
