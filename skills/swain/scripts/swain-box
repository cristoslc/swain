#!/bin/sh
# swain-box — Run Claude Code in a Docker Desktop sandbox (SPEC-067)
# Usage: ./swain-box [path]
#
# With no argument, uses $PWD as the project root.
# With a path argument, uses that directory as the project root.
#
# Sandbox scoping: One sandbox per project directory (named claude-<dirname>).
# Git worktrees do NOT get separate sandboxes — they share the project's
# sandbox. If you need per-worktree isolation, run swain-box from the
# worktree's directory to create a distinct sandbox for it.
#
# Authentication: On first launch, run /login inside the sandbox to
# authenticate with your Claude subscription (Pro/Max). Credentials are
# stored inside the sandbox and reused on subsequent runs.
#
# Note: docker sandbox does NOT forward host shell environment variables
# from the current session. The sandbox daemon reads env vars from your
# shell profile (~/.zshrc) on Docker Desktop startup only.
#
# Requires Docker Desktop 4.58+ (for the 'docker sandbox' subcommand).

set -eu

# --- Argument parsing ---
TARGET_PATH=""
for arg in "$@"; do
    case "$arg" in
        *) TARGET_PATH="$arg" ;;
    esac
done

# --- Docker availability check ---
if ! command -v docker >/dev/null 2>&1; then
    echo "swain-box: 'docker' not found on PATH." >&2
    echo "Install Docker Desktop: https://www.docker.com/products/docker-desktop/" >&2
    exit 1
fi

# --- docker sandbox subcommand check (Docker Desktop 4.58+) ---
if ! docker sandbox --help >/dev/null 2>&1; then
    echo "swain-box: 'docker sandbox' subcommand is not available." >&2
    echo "Requires Docker Desktop 4.58 or later." >&2
    echo "Download: https://www.docker.com/products/docker-desktop/" >&2
    exit 1
fi

# --- Resolve target path ---
TARGET_PATH="${TARGET_PATH:-$PWD}"

# Resolve to absolute path without using realpath (not portable)
ABSOLUTE_PATH="$(cd "$TARGET_PATH" && pwd)" || {
    echo "swain-box: path does not exist or is not accessible: $TARGET_PATH" >&2
    exit 1
}

# --- Derive sandbox name (matches docker sandbox's default: agent-workdir) ---
WORKDIR_NAME="$(basename "$ABSOLUTE_PATH")"
SANDBOX_NAME="claude-${WORKDIR_NAME}"

# --- Fix apiKeyHelper injection (docker/for-mac#7842) ---
# Docker Desktop < 4.60.1 injected 'apiKeyHelper: "echo proxy-managed"' into
# sandbox settings, which overrides OAuth and forces API key mode.
# Clean it up if the sandbox already exists.
if docker sandbox ls --format '{{.Sandbox}}' 2>/dev/null | grep -qx "$SANDBOX_NAME"; then
    _has_helper=$(docker sandbox exec "$SANDBOX_NAME" \
        grep -c '"apiKeyHelper"' ~/.claude/settings.json 2>/dev/null || echo "0")
    if [ "$_has_helper" != "0" ]; then
        echo "swain-box: removing stale apiKeyHelper injection (docker/for-mac#7842)..." >&2
        docker sandbox exec "$SANDBOX_NAME" \
            sed -i '/"apiKeyHelper"/d' ~/.claude/settings.json 2>/dev/null || true
    fi
fi

# --- Launch ---
exec docker sandbox run claude "$ABSOLUTE_PATH" -- --dangerously-skip-permissions
