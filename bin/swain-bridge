#!/usr/bin/env bash
# swain-bridge — start the untethered operator bridge (RUNBOOK-003)
#
# Starts opencode serve and the host bridge. Ctrl-C stops both.
#
# Usage: swain-bridge [--domain <name>] [--port <N>] [--daemon]

set -euo pipefail

DOMAIN="personal"
PORT=4097
VERBOSE=""
DAEMON=false
ACTION="start"
LOG_FILE="/tmp/swain-bridge.log"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --domain) DOMAIN="$2"; shift 2 ;;
    --port) PORT="$2"; shift 2 ;;
    --verbose) VERBOSE="--verbose"; shift ;;
    --daemon) DAEMON=true; shift ;;
    --stop) ACTION="stop"; shift ;;
    --status) ACTION="status"; shift ;;
    --help|-h)
      echo "Usage: swain-bridge [--domain <name>] [--port <N>] [--verbose] [--daemon] [--stop] [--status]"
      echo ""
      echo "Starts the untethered operator bridge:"
      echo "  1. opencode serve on the specified port"
      echo "  2. untethered-host connecting Zulip to opencode"
      echo ""
      echo "Options:"
      echo "  --domain NAME  Security domain (default: personal)"
      echo "  --port N       opencode serve port (default: 4097)"
      echo "  --verbose      Enable debug logging"
      echo "  --daemon       Run in background (detached from terminal)"
      echo "  --stop         Stop running daemon"
      echo "  --status       Show daemon status and health"
      exit 0
      ;;
    *) echo "Unknown option: $1" >&2; exit 1 ;;
  esac
done

# Runtime state is managed by untethered, not this script.
# swain-bridge only handles process startup/shutdown.

# Handle status action
if [[ "$ACTION" == "status" ]]; then
  echo "swain-bridge status:"
  
  # Check opencode serve
  if curl -s "http://127.0.0.1:$PORT/global/health" | grep -q '"healthy":true' 2>/dev/null; then
    echo "  opencode serve (port $PORT): running"
  else
    echo "  opencode serve (port $PORT): not running"
  fi
  
  echo ""
  echo "For detailed bridge status, run:"
  echo "  uv run python -m untethered.main --domain $DOMAIN --status"
  exit 0
fi

# Handle stop action
if [[ "$ACTION" == "stop" ]]; then
  echo "Stopping swain-bridge..."
  
  # Kill opencode serve if we started it
  OPENCODE_PID=$(pgrep -f "opencode serve.*--port $PORT" | head -1 || true)
  if [[ -n "$OPENCODE_PID" ]]; then
    kill "$OPENCODE_PID" 2>/dev/null && echo "  opencode serve stopped."
  fi
  
  # Bridge is managed by untethered - no direct PID file
  echo "  Note: Use 'pkill -f untethered-host' if bridge is still running"
  echo "Cleanup complete."
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Track child PIDs for cleanup.
OPENCODE_PID=""
BRIDGE_PID=""

if [[ "$DAEMON" == "true" ]]; then
  # Daemon mode - detach from terminal
  echo "Starting swain-bridge in daemon mode..."
  
  # Start opencode serve if not running
  if ! curl -s "http://127.0.0.1:$PORT/global/health" | grep -q '"healthy":true' 2>/dev/null; then
    echo "Starting opencode serve on port $PORT..."
    nohup opencode serve --port "$PORT" --print-logs >> "$LOG_FILE" 2>&1 &
    OPENCODE_PID=$!
    
    # Wait for health
    for i in $(seq 1 30); do
      if curl -s "http://127.0.0.1:$PORT/global/health" | grep -q '"healthy":true' 2>/dev/null; then
        echo "opencode serve ready."
        break
      fi
      sleep 0.5
    done
  else
    echo "opencode serve already running on port $PORT."
    # Find existing PID
    OPENCODE_PID=$(pgrep -f "opencode serve.*--port $PORT" | head -1)
  fi
  
  # Start bridge - untethered manages its own PID tracking
  echo "Starting bridge (domain: $DOMAIN)..."
  cd "$REPO_ROOT"
  nohup uv run untethered-host --domain "$DOMAIN" $VERBOSE >> "$LOG_FILE" 2>&1 &
  BRIDGE_PID=$!
  
  echo "swain-bridge started"
  echo "Logs: $LOG_FILE"
  echo ""
  echo "Operator can attach: opencode attach http://127.0.0.1:$PORT"
  echo "Send messages in Zulip #swain > control."
  echo "Use 'swain-bridge --stop' to stop."
  exit 0
else
  # Foreground mode - existing behavior
  cleanup() {
    echo ""
    echo "Shutting down..."
    [[ -n "$BRIDGE_PID" ]] && kill "$BRIDGE_PID" 2>/dev/null && echo "  Bridge stopped."
    [[ -n "$OPENCODE_PID" ]] && kill "$OPENCODE_PID" 2>/dev/null && echo "  opencode serve stopped."
    wait 2>/dev/null
  }
  trap cleanup EXIT INT TERM

  # 1. Start opencode serve if not already running.
  if curl -s "http://127.0.0.1:$PORT/global/health" | grep -q '"healthy":true' 2>/dev/null; then
    echo "opencode serve already running on port $PORT."
  else
    echo "Starting opencode serve on port $PORT..."
    opencode serve --port "$PORT" --print-logs 2>/tmp/opencode-serve.log &
    OPENCODE_PID=$!

    # Wait for health.
    for i in $(seq 1 30); do
      if curl -s "http://127.0.0.1:$PORT/global/health" | grep -q '"healthy":true' 2>/dev/null; then
        echo "opencode serve ready."
        break
      fi
      sleep 0.5
    done
  fi

  echo ""
  echo "Operator can attach: opencode attach http://127.0.0.1:$PORT"
  echo ""

  # 2. Start the bridge.
  echo "Starting bridge (domain: $DOMAIN)..."
  cd "$REPO_ROOT"
  uv run untethered-host --domain "$DOMAIN" $VERBOSE &
  BRIDGE_PID=$!

  echo "Bridge running. Send messages in Zulip #swain > control."
  echo "Press Ctrl-C to stop."
  echo ""

  # Wait for either child to exit.
  wait
fi
